# Cloudflare Turnstile — https://dash.cloudflare.com/ → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# Make.com Webhooks
NEXT_PUBLIC_CONTACT_WEBHOOK=https://hook.eu1.make.com/vwa9gpe5djg1jujxd6cb78qgpo2dwn3v
REVIEW_WEBHOOK=your_review_webhook_url_here

# Local reviews CSV (Google Sheets published as CSV — for user-submitted reviews)
NEXT_PUBLIC_LOCAL_CSV=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?output=csv

# Cloudinary (required for review photos to persist)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
